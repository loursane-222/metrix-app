generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  ad            String    @default("")
  aktif         Boolean   @default(true)
  abonelikBitis DateTime?
  abonelikPlani  String    @default("demo")
  createdAt     DateTime  @default(now())

  atolye Atolye?

  pushTokens PushToken[]
}

model Atolye {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  atolyeAdi   String @default("")
  sehir       String @default("")
  ilce        String @default("")
  telefon     String @default("")
  email       String @default("")
  adres       String @default("")
  logoUrl     String @default("")
  kurulusYili Int    @default(0)

  toplamMaas  Decimal @default(0)
  sgkGideri   Decimal @default(0)
  yemekGideri Decimal @default(0)
  yolGideri   Decimal @default(0)

  kira     Decimal @default(0)
  elektrik Decimal @default(0)
  su       Decimal @default(0)
  dogalgaz Decimal @default(0)
  internet Decimal @default(0)

  sarfMalzeme Decimal @default(0)

  aylikPorselenPlaka Int @default(0)
  aylikKuvarsPlaka   Int @default(0)
  aylikDogaltasPlaka Int @default(0)

  plakaBasinaMtul  Decimal @default(3.20)
  dakikaMaliyeti   Decimal @default(0)
  kdvOrani         Int     @default(20)
  teklifGecerlilik Int     @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  makineler   Makine[]
  araclar     Arac[]
  isler        Is[]
  personeller Personel[]
  musteriler  Musteri[]
  aylikGiderler AylikGider[]
  odemeSablonlari OdemeSablonu[]
}

model Makine {
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  makineAdi              String
  alinanBedel            Decimal
  paraBirimi             String  @default("TRY")
  amortismanSuresiAy     Int
  aylikAktifCalismaSaati Decimal

  aylikAmortisman  Decimal @default(0)
  saatlikMaliyet   Decimal @default(0)
  dakikalikMaliyet Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  operasyonlar IsOperasyon[]
}

model Arac {
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  aracAdi            String
  aracTipi           String
  alinanBedel        Decimal
  paraBirimi         String  @default("TRY")
  amortismanSuresiAy Int

  aylikBakim        Decimal @default(0)
  aylikSigortaKasko Decimal @default(0)
  aylikVergiMuayene Decimal @default(0)

  aylikAmortisman         Decimal @default(0)
  aylikToplamSabitMaliyet Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Musteri {
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  firmaAdi       String  @default("")
  ad             String  @default("")
  soyad          String  @default("")
  telefon        String  @default("")
  email          String  @default("")
  acilisBakiyesi Decimal @default(0)
  bakiyeTipi     String  @default("borc")
  musteriTipi    String  @default("son_kullanici")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isler        Is[]
  tahsilatlar  Tahsilat[]
  odemePlanlari OdemePlani[]
}

model Tahsilat {
  id        String  @id @default(cuid())
  musteriId String
  musteri   Musteri @relation(fields: [musteriId], references: [id], onDelete: Cascade)

  tarih DateTime
  tutar Decimal  @default(0)

  isId  String?
  is    Is?      @relation(fields: [isId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Is {
  versiyon Int    @default(1)
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  musteriId String?
  musteri   Musteri? @relation(fields: [musteriId], references: [id])

  teklifNo    String @default("")
  musteriAdi  String @default("")
  urunAdi     String
  malzemeTipi String
  musteriTipi String

  plakaFiyatiEuro   Decimal
  metrajMtul        Decimal
  birMtulDakika     Decimal
  tezgahArasiMtul   Decimal @default(0)
  tezgahArasiDakika Decimal @default(0)
  adaTezgahMtul     Decimal @default(0)
  adaTezgahDakika   Decimal @default(0)
  kullanilanKur     Decimal @default(0)

  plakaGenislikCm    Decimal @default(0)
  plakaUzunlukCm     Decimal @default(0)
  plakadanAlinanMtul Decimal @default(0)

  kullanilanPlakaSayisi Decimal @default(0)

  karYuzdesi Decimal

  toplamSureDakika Decimal @default(0)
  iscilikMaliyeti  Decimal @default(0)
  malzemeMaliyeti  Decimal @default(0)
  toplamMaliyet    Decimal @default(0)
  kdvTutari        Decimal @default(0)
  kdvDahilFiyat    Decimal @default(0)
  satisFiyati      Decimal @default(0)
  mtulSatisFiyati  Decimal @default(0)

  tezgahBirimFiyatOverride      Decimal @default(0)
  tezgahArasiBirimFiyatOverride Decimal @default(0)
  adaBirimFiyatOverride         Decimal @default(0)

  teklifGecerlilikTarihi DateTime?

  teklifGoruntulenmeSayisi    Int       @default(0)
  teklifIlkGoruntulenmeTarihi DateTime?
  teklifSonGoruntulenmeTarihi DateTime?
  kirilanTasPlaka             Decimal   @default(0)
  hataliKesimPlaka            Decimal   @default(0)

  durum String @default("teklif_verildi")

  tasDurumu String?

  whatsappOnay       Boolean @default(false)
  whatsappOnayOkundu Boolean @default(false)

  isTarihi DateTime?

  tahsilat         Decimal   @default(0)
  onaylanmaTarihi  DateTime?
  kaybedilmeTarihi DateTime?
  notlar           String?
  plakaLayoutJson Json?
  plakaImageUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  odemePlani   OdemePlani?
  tahsilatlar  Tahsilat[]
  operasyonlar IsOperasyon[]
  workSchedule WorkSchedule?
}

model IsOperasyon {
  id   String @id @default(cuid())
  isId String
  is   Is     @relation(fields: [isId], references: [id])

  operasyonTipi String

  makineId String?
  makine   Makine? @relation(fields: [makineId], references: [id])

  adet         Int
  birimDakika  Decimal
  toplamDakika Decimal

  createdAt DateTime @default(now())
}

enum PhaseType {
  OLCU
  IMALAT
  MONTAJ
}

enum PhaseExecutionStatus {
  PLANNED
  STARTED
  PAUSED
  CANNOT_START
  COMPLETED
  CANCELLED
  RESCHEDULE_REQUESTED
}

enum PersonelRolGrubu {
  OLCU
  KESIM
  TOPLAMA
  MONTAJ
  OFIS
  DIGER
}

model WorkSchedule {
  id   String @id @default(cuid())
  isId String @unique
  is   Is     @relation(fields: [isId], references: [id], onDelete: Cascade)

  startDate DateTime?
  endDate   DateTime?
  notes     String?

  phases SchedulePhase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_schedules")
}

model SchedulePhase {
  id             String       @id @default(cuid())
  workScheduleId String
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  phase        PhaseType
  plannedStart DateTime?
  plannedEnd   DateTime?

  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?

  isOverridden Boolean @default(false)
  overrideNote String?
  notes        String?

  photoUrl        String?
  photoUploadedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fazAtamalar FazAtama[]
  executions  PhaseExecution[]

  @@unique([workScheduleId, phase])
  @@map("schedule_phases")
}

model Personel {
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  ad            String
  soyad         String
  gorevi        String
  bagliOlduguId String?
  bagliOldugu   Personel?  @relation("PersonelHiyerarsi", fields: [bagliOlduguId], references: [id])
  altPersonel   Personel[] @relation("PersonelHiyerarsi")

  calismaYili Int     @default(0)
  telefon     String  @default("")
  email       String  @default("")
  password    String  @default("")
  aktif       Boolean @default(true)

  rolGrubu         PersonelRolGrubu @default(DIGER)
  brutMaas         Decimal          @default(0)
  sgkOrani         Decimal          @default(20.5)
  iseBaslamaTarihi DateTime?
  gunlukCalismaGun Int              @default(5)
  userId           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fazAtamalar     FazAtama[]
  phaseExecutions PhaseExecution[]

  @@map("personel")
}

model FazAtama {
  id              String        @id @default(cuid())
  schedulePhaseId String
  schedulePhase   SchedulePhase @relation(fields: [schedulePhaseId], references: [id], onDelete: Cascade)

  personelId String
  personel   Personel @relation(fields: [personelId], references: [id])

  createdAt DateTime @default(now())

  @@unique([schedulePhaseId, personelId])
  @@map("faz_atamalar")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  atolyeId    String  @default("")
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  actionUrl   String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TeklifEvent {
  id        String   @id @default(cuid())
  teklifNo  String
  event     String
  meta      String?
  createdAt DateTime @default(now())
}


model ActivityLog {
  id        String   @id @default(cuid())
  atolyeId  String
  userId    String?
  personelId String?
  type      String
  message   String
  refId     String?
  eventType String?
  category  String?
  severity  String?
  source    String?
  title     String?
  url       String?
  refType   String?
  actorId   String?
  actorName String?
  attachmentUrl String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([atolyeId])
  @@index([createdAt])
}

model AylikGider {
  id       String @id @default(cuid())
  atolyeId String
  atolye   Atolye @relation(fields: [atolyeId], references: [id])

  tarih     DateTime
  kategori  String   // toplamMaas | sgkGideri | yemekGideri | yolGideri | kira | elektrik | su | dogalgaz | internet | sarfMalzeme | diger
  aciklama  String   @default("")
  tutar     Decimal

  createdAt DateTime @default(now())

  @@index([atolyeId])
  @@index([atolyeId, kategori])
}

model OdemePlani {
  id       String @id @default(cuid())
  isId     String @unique
  is       Is     @relation(fields: [isId], references: [id], onDelete: Cascade)
  musteriId String
  musteri  Musteri @relation(fields: [musteriId], references: [id])

  toplamTutar  Decimal
  musteriTipi  String

  taksitler OdemeTaksiti[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odeme_planlari")
}

model OdemeTaksiti {
  id           String     @id @default(cuid())
  planId       String
  plan         OdemePlani @relation(fields: [planId], references: [id], onDelete: Cascade)

  taksitNo     Int
  aciklama     String
  vadeTarihi   DateTime
  tutar        Decimal
  odendiMi     Boolean  @default(false)
  odenmeTarihi DateTime?

  createdAt DateTime @default(now())

  @@map("odeme_taksitleri")
}

model PersonelPushToken {
  id         String   @id @default(cuid())
  personelId String
  atolyeId   String
  token      String   @unique
  createdAt  DateTime @default(now())

  @@index([atolyeId])
}

model OdemeSablonu {
  id          String @id @default(cuid())
  atolyeId    String
  atolye      Atolye @relation(fields: [atolyeId], references: [id], onDelete: Cascade)

  musteriTipi String  // bayi, mimar, muteahhit, son_kullanici, imalatci
  ad          String  // "Standart", "Esnek", "Peşinatsız" gibi
  aciklama    String  @default("")
  sira        Int     @default(0) // 1,2,3 - hangi sırada gösterilsin

  taksitler   Json    // [{ taksitNo, aciklama, yuzde, gunSonra }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odeme_sablonlari")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Execution Engine (Faz 3A) ────────────────────────────────────────────────
// SchedulePhase = plan entity (değişmez)
// PhaseExecution = gerçek operasyon oturumu (additive, parallel)

model PhaseExecution {
  id              String               @id @default(cuid())
  schedulePhaseId String
  schedulePhase   SchedulePhase        @relation(fields: [schedulePhaseId], references: [id], onDelete: Cascade)

  personelId      String?
  personel        Personel?            @relation(fields: [personelId], references: [id], onDelete: SetNull)

  atolyeId        String               // denormalize — sorgu performansı

  status          PhaseExecutionStatus @default(PLANNED)

  plannedStartAt  DateTime?            // SchedulePhase.plannedStart snapshot
  plannedEndAt    DateTime?

  actualStartedAt DateTime?            // STARTED event anı
  actualEndedAt   DateTime?            // COMPLETED event anı

  estimatedMinutes Int?                // Is.toplamSureDakika snapshot

  // actualMinutes: kaynak değil, event/session'dan türetilecek cache
  // Şu an null bırakılabilir; endpoint yazılırken event'lerden hesaplanır
  actualMinutes   Int?

  // pauseMinutes: ileride session modeli tamamlandığında event'lerden türetilecek
  // Şu an null bırakılabilir
  pauseMinutes    Int?

  mtul            Decimal?             // gerçek üretim miktarı (mtül)
  machineId       String?              // FK yok, ileride Makine ilişkisi eklenebilir

  notes           String?
  cannotStartReason   String?          // CannotStartReason değeri (string)
  failureDescription  String?          // taş kırıldı vb. serbest metin detay
  materialLossCost    Decimal?         // TL cinsinden tahmini maliyet kaybı

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  events          PhaseExecutionEvent[]

  @@index([schedulePhaseId])
  @@index([atolyeId])
  @@index([personelId])
  @@map("phase_executions")
}

model PhaseExecutionEvent {
  id               String         @id @default(cuid())
  phaseExecutionId String
  phaseExecution   PhaseExecution @relation(fields: [phaseExecutionId], references: [id], onDelete: Cascade)

  schedulePhaseId  String         // denormalize — direkt faz bazlı sorgu
  personelId       String?        // eventi gerçekleştiren personel
  atolyeId         String         // denormalize

  eventType        String         // PhaseExecutionEventType değeri (string)
  note             String?
  metadata         Json?

  actorType        String?
  actorUserId      String?
  actorPersonelId  String?
  operationStep    String?
  fromStatus       String?
  toStatus         String?
  reasonCode       String?
  costType         String?
  costAmount       Decimal?
  currency         String?
  attachmentUrl    String?
  attachmentType   String?

  createdAt        DateTime       @default(now())

  @@index([phaseExecutionId])
  @@index([schedulePhaseId])
  @@index([atolyeId])
  @@index([atolyeId, createdAt])
  @@index([operationStep])
  @@index([eventType])
  @@index([actorPersonelId])
  @@index([actorUserId])
  @@map("phase_execution_events")
}
