"use client";

import { useEffect, useState } from "react";
import { useRouter } from "next/navigation";

type CurrentUser = {
  userId?: string | null;
  email?: string | null;
  aktif?: boolean;
  abonelikBitis?: string | null;
};

const IBAN = "TR00 0000 0000 0000 0000 0000 00";
const ALICI = "METRIX TEZGAH";
const FIYAT = "149 USD";

export default function AbonelikPage() {
  const router = useRouter();
  const [user, setUser] = useState<CurrentUser | null>(null);
  const [loading, setLoading] = useState(true);
  const [odemeAcik, setOdemeAcik] = useState(false);
  const [kopyalandi, setKopyalandi] = useState("");

  useEffect(() => {
    fetch("/api/auth/current-user", { credentials: "include", cache: "no-store" })
      .then((r) => {
        if (!r.ok) throw new Error("Yetkisiz");
        return r.json();
      })
      .then((data) => {
        setUser(data);
        if (data?.aktif) router.push("/dashboard");
      })
      .catch(() => router.push("/login"))
      .finally(() => setLoading(false));
  }, [router]);

  async function kopyala(text: string, label: string) {
    try {
      await navigator.clipboard.writeText(text);
      setKopyalandi(label);
      setTimeout(() => setKopyalandi(""), 1800);
    } catch {
      setKopyalandi("");
    }
  }

  function whatsappPaylas() {
    const mesaj = encodeURIComponent(
      `Merhaba, Metrix Tezgah aboneliği için ödeme bilgisi:\n\nPaket: Aylık Premium\nTutar: ${FIYAT}\nAlıcı: ${ALICI}\nIBAN: ${IBAN}\nKullanıcı: ${user?.email || "-"}\n\nÖdeme sonrası hesabımın aktif edilmesini rica ederim.`
    );
    window.open(`https://wa.me/?text=${mesaj}`, "_blank");
  }

  async function cikisYap() {
    await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
    window.location.href = "/login";
  }

  if (loading) {
    return (
      <div className="flex min-h-[100dvh] items-center justify-center bg-[#030712] text-slate-400">
        Abonelik durumu kontrol ediliyor...
      </div>
    );
  }

  return (
    <div className="relative min-h-[100dvh] overflow-hidden bg-[#030712] text-white">
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.26),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.22),transparent_32%),linear-gradient(135deg,#030712_0%,#07111f_45%,#0B1020_100%)]" />
      <div className="absolute -left-28 top-20 h-80 w-80 rounded-full bg-blue-500/20 blur-[120px]" />
      <div className="absolute right-0 top-1/3 h-96 w-96 rounded-full bg-violet-500/20 blur-[130px]" />

      <main className="relative z-10 mx-auto flex min-h-[100dvh] w-full max-w-7xl items-center px-5 py-8 lg:px-8">
        <div className="grid w-full gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <section>
            <div className="mb-6 flex items-center gap-3">
              <div className="flex h-14 w-14 items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-white/10">
                <img src="/icon.png" alt="Metrix" className="h-full w-full object-cover" />
              </div>
              <div>
                <p className="text-[11px] font-semibold uppercase tracking-[0.28em] text-white/40">
                  Metrix Tezgah
                </p>
                <h1 className="mt-1 text-lg font-bold">Premium Abonelik</h1>
              </div>
            </div>

            <div className="rounded-[34px] border border-white/10 bg-white/[0.06] p-6 shadow-[0_30px_90px_rgba(0,0,0,0.45)] backdrop-blur-2xl sm:p-8">
              <span className="inline-flex rounded-full border border-amber-300/20 bg-amber-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-amber-200">
                Hesap Onayı Bekliyor
              </span>

              <h2 className="mt-6 max-w-2xl text-4xl font-black leading-[1.05] tracking-tight sm:text-5xl">
                Atölyeni yönetmeye başlamak için aboneliğini aktif et.
              </h2>

              <p className="mt-5 max-w-xl text-base leading-7 text-slate-300">
                Kayıt işlemin tamamlandı. Metrix’i aktif kullanabilmek için ödeme yaptıktan sonra admin onayı gerekir.
                Onay sonrası teklif, müşteri, iş programı ve maliyet modülleri açılır.
              </p>

              <div className="mt-7 grid gap-3 sm:grid-cols-3">
                {[
                  ["Teklif Motoru", "Maliyet ve satış fiyatı kontrolü"],
                  ["İş Programı", "Ölçü, imalat, montaj takibi"],
                  ["CRM", "Müşteri bakiye ve ekstre takibi"],
                ].map(([title, desc]) => (
                  <div key={title} className="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
                    <p className="text-sm font-bold">{title}</p>
                    <p className="mt-2 text-xs leading-5 text-slate-400">{desc}</p>
                  </div>
                ))}
              </div>

              <div className="mt-7 flex flex-col gap-3 sm:flex-row">
                <button
                  onClick={() => setOdemeAcik(true)}
                  className="rounded-2xl bg-gradient-to-r from-blue-600 to-violet-600 px-6 py-4 text-sm font-bold text-white shadow-[0_18px_50px_rgba(37,99,235,0.35)] transition hover:scale-[1.01]"
                >
                  Ödeme Bilgilerini Göster
                </button>

                <button
                  onClick={cikisYap}
                  className="rounded-2xl border border-white/10 bg-white/5 px-6 py-4 text-sm font-semibold text-slate-200 transition hover:bg-white/10"
                >
                  Çıkış Yap
                </button>
              </div>

              <p className="mt-5 text-xs text-slate-500">
                Giriş yapan hesap: {user?.email || "—"}
              </p>
            </div>
          </section>

          <aside className="rounded-[34px] border border-white/10 bg-[#08111f]/80 p-6 shadow-[0_30px_90px_rgba(0,0,0,0.42)] backdrop-blur-2xl sm:p-8">
            <div className="rounded-[28px] border border-blue-400/20 bg-gradient-to-br from-blue-500/20 via-violet-500/15 to-white/[0.03] p-6">
              <p className="text-xs font-semibold uppercase tracking-[0.24em] text-blue-200">
                Tek Paket
              </p>

              <div className="mt-5 flex items-end gap-2">
                <span className="text-5xl font-black">149$</span>
                <span className="mb-2 text-sm text-slate-400">/ ay</span>
              </div>

              <p className="mt-4 text-sm leading-6 text-slate-300">
                Mermer ve porselen tezgah atölyeleri için teklif, operasyon, müşteri ve kârlılık yönetimi.
              </p>

              <div className="mt-6 space-y-3">
                {[
                  "Sınırsız müşteri kaydı",
                  "Teklif ve PDF yönetimi",
                  "İş programı ve günlük plan",
                  "Maliyet, kâr ve tahsilat takibi",
                  "WhatsApp'tan teklif onaylama",
                  "AI destekli satış onaylatma",
                ].map((item) => (
                  <div key={item} className="flex items-center gap-3 text-sm text-slate-200">
                    <span className="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-400/15 text-emerald-300">✓</span>
                    {item}
                  </div>
                ))}
              </div>

              <button
                onClick={() => setOdemeAcik(true)}
                className="mt-7 w-full rounded-2xl bg-white px-5 py-4 text-sm font-black text-slate-950 transition hover:bg-blue-50"
              >
                Aboneliği Başlat
              </button>
            </div>

            <div className="mt-4 rounded-2xl border border-white/10 bg-white/[0.04] p-4 text-xs leading-6 text-slate-400">
              Ödeme manuel onaylanır. Ödeme sonrası admin panelinden hesabın aktif edilir.
            </div>
          </aside>
        </div>
      </main>

      {odemeAcik && (
        <div className="fixed inset-0 z-[200] flex items-center justify-center bg-black/70 p-4 backdrop-blur-sm">
          <div className="w-full max-w-lg rounded-[30px] border border-white/10 bg-[#0B1120] p-6 text-white shadow-[0_40px_100px_rgba(0,0,0,0.6)]">
            <div className="flex items-start justify-between gap-4">
              <div>
                <p className="text-[11px] font-semibold uppercase tracking-[0.24em] text-blue-300">
                  Ödeme Bilgileri
                </p>
                <h3 className="mt-2 text-2xl font-black">Aylık Premium Abonelik</h3>
              </div>

              <button
                onClick={() => setOdemeAcik(false)}
                className="rounded-xl border border-white/10 px-3 py-2 text-white/60 hover:bg-white/10"
              >
                ✕
              </button>
            </div>

            <div className="mt-6 space-y-3">
              <div className="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
                <p className="text-xs text-slate-500">Tutar</p>
                <p className="mt-1 text-xl font-black">{FIYAT}</p>
              </div>

              <div className="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
                <p className="text-xs text-slate-500">Alıcı</p>
                <div className="mt-1 flex items-center justify-between gap-3">
                  <p className="font-bold">{ALICI}</p>
                  <button onClick={() => kopyala(ALICI, "Alıcı")} className="text-xs text-blue-300">
                    Kopyala
                  </button>
                </div>
              </div>

              <div className="rounded-2xl border border-white/10 bg-white/[0.04] p-4">
                <p className="text-xs text-slate-500">IBAN</p>
                <div className="mt-1 flex items-center justify-between gap-3">
                  <p className="break-all font-mono text-sm font-bold">{IBAN}</p>
                  <button onClick={() => kopyala(IBAN, "IBAN")} className="shrink-0 text-xs text-blue-300">
                    Kopyala
                  </button>
                </div>
              </div>

              {kopyalandi && (
                <div className="rounded-2xl border border-emerald-400/20 bg-emerald-500/10 p-3 text-sm text-emerald-300">
                  {kopyalandi} kopyalandı.
                </div>
              )}
            </div>

            <div className="mt-6 grid gap-3 sm:grid-cols-2">
              <button
                onClick={whatsappPaylas}
                className="rounded-2xl bg-emerald-600 px-5 py-4 text-sm font-bold text-white hover:bg-emerald-500"
              >
                WhatsApp ile Paylaş
              </button>

              <button
                onClick={() => setOdemeAcik(false)}
                className="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-sm font-semibold text-slate-200 hover:bg-white/10"
              >
                Kapat
              </button>
            </div>

            <p className="mt-5 text-xs leading-5 text-slate-500">
              Açıklama kısmına kayıtlı e-posta adresini yazman önerilir: {user?.email || "—"}
            </p>
          </div>
        </div>
      )}
    </div>
  );
}
