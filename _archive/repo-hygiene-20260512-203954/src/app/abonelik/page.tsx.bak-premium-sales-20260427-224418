"use client";

import { useEffect, useState } from "react";

const IBAN = "TR83 0006 2000 2690 0006 6417 03";
const ALICI = "Murat Arda";
const BANKA = "Garanti Bankası";
const FIYAT = "149 USD";

export default function AbonelikPage() {
  const [email, setEmail] = useState("");
  const [modal, setModal] = useState(false);
  const [copied, setCopied] = useState("");

  useEffect(() => {
    fetch("/api/auth/current-user", { credentials: "include" })
      .then((r) => r.json())
      .then((d) => setEmail(d?.email || ""));
  }, []);

  async function copy(text: string, label: string) {
    await navigator.clipboard.writeText(text);
    setCopied(label + " kopyalandı");
    setTimeout(() => setCopied(""), 1500);
  }

  function whatsapp() {
    const msg = encodeURIComponent(
      `Merhaba, Metrix aboneliğimi aktif etmek istiyorum.

Paket: Premium
Tutar: ${FIYAT}
Alıcı: ${ALICI}
Banka: ${BANKA}
IBAN: ${IBAN}
E-posta: ${email}

Ödeme yaptım, hesabımı açar mısınız?`
    );
    window.open(`https://wa.me/?text=${msg}`, "_blank");
  }

  async function logout() {
    await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
    window.location.href = "/login";
  }

  return (
    <div className="min-h-screen bg-[#030712] text-white flex items-center justify-center px-5">
      <div className="max-w-5xl w-full grid lg:grid-cols-2 gap-8">

        {/* SOL */}
        <div>
          <h1 className="text-4xl font-black leading-tight">
            Metrix’i kullanmıyorsan <br />
            <span className="text-red-400">her gün satış kaçırıyorsun.</span>
          </h1>

          <p className="mt-5 text-slate-300 text-lg">
            Teklif gönderiyorsun ama dönüş yok.<br />
            Müşteri “bakacağım” diyor, kayboluyor.<br />
            Takip edemiyorsun.
          </p>

          <p className="mt-5 text-lg font-semibold text-emerald-300">
            Metrix bunu çözer.
          </p>

          <div className="mt-6 space-y-3">
            {[
              "WhatsApp’tan teklif gönder → müşteri anında onaylasın",
              "AI sana hangi müşterinin kapanacağını söylesin",
              "Takip etmeyi bırak → sistem sana hatırlatsın",
              "Teklifleri kaybetmeyi bırak",
            ].map((x) => (
              <div key={x} className="flex gap-3">
                <span className="text-emerald-400">✓</span>
                <span>{x}</span>
              </div>
            ))}
          </div>

          <button
            onClick={() => setModal(true)}
            className="mt-8 bg-blue-600 px-6 py-4 rounded-xl font-bold text-lg hover:bg-blue-500"
          >
            Aboneliği Aç
          </button>

          <button
            onClick={logout}
            className="mt-4 text-sm text-slate-400 underline"
          >
            çıkış yap
          </button>

          <p className="mt-4 text-xs text-slate-500">
            giriş: {email}
          </p>
        </div>

        {/* SAĞ */}
        <div className="bg-[#0B1120] p-6 rounded-2xl border border-white/10">
          <p className="text-sm text-slate-400">Tek Paket</p>

          <h2 className="text-5xl font-black mt-2">
            149$
          </h2>

          <p className="text-slate-400 mt-1">/ ay</p>

          <p className="mt-5 text-slate-300">
            1 satış kapatsan zaten kendini çıkarır.
          </p>

          <div className="mt-6 space-y-2 text-sm">
            <p>• Sınırsız müşteri</p>
            <p>• Teklif + PDF sistemi</p>
            <p>• İş programı</p>
            <p>• Tahsilat takibi</p>
            <p>• AI satış sistemi</p>
          </div>

          <button
            onClick={() => setModal(true)}
            className="mt-6 w-full bg-white text-black py-3 rounded-xl font-bold"
          >
            Ödeme Bilgilerini Göster
          </button>
        </div>
      </div>

      {/* MODAL */}
      {modal && (
        <div className="fixed inset-0 bg-black/80 flex items-center justify-center">
          <div className="bg-[#0B1120] p-6 rounded-2xl w-full max-w-md">

            <h2 className="text-xl font-bold">Ödeme Bilgileri</h2>

            <div className="mt-4 space-y-3">

              <div>
                <p className="text-xs text-slate-400">Tutar</p>
                <p className="font-bold">{FIYAT}</p>
              </div>

              <div>
                <p className="text-xs text-slate-400">Alıcı</p>
                <div className="flex justify-between">
                  <p>{ALICI}</p>
                  <button onClick={() => copy(ALICI,"Alıcı")}>kopyala</button>
                </div>
              </div>

              <div>
                <p className="text-xs text-slate-400">Banka</p>
                <p>{BANKA}</p>
              </div>

              <div>
                <p className="text-xs text-slate-400">IBAN</p>
                <div className="flex justify-between">
                  <p>{IBAN}</p>
                  <button onClick={() => copy(IBAN,"IBAN")}>kopyala</button>
                </div>
              </div>

              {copied && <p className="text-emerald-400 text-sm">{copied}</p>}
            </div>

            <button
              onClick={whatsapp}
              className="mt-6 w-full bg-emerald-600 py-3 rounded-xl font-bold"
            >
              WhatsApp ile bildir
            </button>

            <button
              onClick={() => setModal(false)}
              className="mt-3 w-full border border-white/10 py-3 rounded-xl"
            >
              kapat
            </button>

          </div>
        </div>
      )}
    </div>
  );
}
