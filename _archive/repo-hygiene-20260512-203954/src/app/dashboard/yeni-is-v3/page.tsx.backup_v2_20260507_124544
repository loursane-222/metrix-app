              initialProductName={form.urunAdi} initialPlakaGenislik={form.plakaGenislikCm}
              initialPlakaYukseklik={form.plakaUzunlukCm} initialPlakaFiyati={form.plakaFiyatiEuro}
              initialRows={plakaInitialRows} onApply={aiAktar} />
          </div>
        </div>
      )}
    </div>
  );
}

// ─── Operasyon Satırı Bileşeni ────────────────────────────────────────────────
function OperasyonSatiri({ label, mtul, setMtul, dakika, setDakika, makineId, setMakineId, makineler, gelismis }: any) {
  const aktif = n(mtul) > 0;
  return (
    <div style={{
      display: "grid",
      gridTemplateColumns: gelismis ? "120px 90px 90px 1fr" : "1fr 90px",
      gap: "8px", alignItems: "end",
      padding: "10px 12px", borderRadius: "14px",
      border: `1px solid ${aktif ? "rgba(16,185,129,0.25)" : "#1f2937"}`,
      background: aktif ? "rgba(16,185,129,0.04)" : "#0a0f1a",
      transition: "all .15s",
    }}>
      <div>
        <p style={{ fontSize: "11px", color: aktif ? "#6ee7b7" : "#6b7280", marginBottom: "4px", fontWeight: aktif ? 600 : 400 }}>{label}</p>
        <input
          value={mtul}
          onChange={(e) => setMtul(e.target.value)}
          onBlur={(e) => setMtul(normalizeMtulDisplay(e.target.value))}
          placeholder="0.00 mtül"
          style={{ width: "100%", background: "#111827", border: `1.5px solid ${aktif ? "rgba(16,185,129,0.4)" : "#1f2937"}`, borderRadius: "10px", padding: "8px 10px", color: "#f9fafb", fontSize: "14px", outline: "none" }}
        />
      </div>
      {gelismis && (
        <>
          <div>
            <p style={{ fontSize: "11px", color: "#6b7280", marginBottom: "4px" }}>dk/mtül</p>
            <input
              value={dakika}
              onChange={(e) => setDakika(e.target.value)}
              placeholder="0"
              style={{ width: "100%", background: "#111827", border: "1.5px solid #1f2937", borderRadius: "10px", padding: "8px 10px", color: "#f9fafb", fontSize: "14px", outline: "none" }}
            />
          </div>
          <div>
            <p style={{ fontSize: "11px", color: "#6b7280", marginBottom: "4px" }}>Makine</p>
            <select
              value={makineId}
              onChange={(e) => setMakineId(e.target.value)}
              style={{ width: "100%", background: "#111827", border: "1.5px solid #1f2937", borderRadius: "10px", padding: "8px 6px", color: "#f9fafb", fontSize: "12px", outline: "none" }}
            >
              {makineler.length === 0 && <option value="">Makine yok</option>}
              {makineler.map((m: any) => (
                <option key={m.id} value={m.id}>
                  {m.makineAdi} · {Number(m.dakikalikMaliyet ?? m.dkMaliyet ?? m.dakikaMaliyet ?? m.hesaplananDakikaMaliyeti ?? 0).toFixed(1)}₺/dk
                </option>
              ))}
            </select>
          </div>
        </>
      )}
      {!gelismis && (
        <div style={{ textAlign: "right" }}>
          <p style={{ fontSize: "11px", color: "#6b7280", marginBottom: "4px" }}>dk/mtül</p>
          <input
            value={dakika}
            onChange={(e) => setDakika(e.target.value)}
            placeholder="0"
            style={{ width: "100%", background: "#111827", border: "1.5px solid #1f2937", borderRadius: "10px", padding: "8px 10px", color: "#f9fafb", fontSize: "14px", outline: "none" }}
          />
        </div>
      )}
    </div>
  );
}

// ─── Fiyat Kontrol Paneli Modal ───────────────────────────────────────────────
function FiyatPanelModal({ satirlar, fiyatOverride, setFiyatOverride, toplam, kar, karYuzde, maliyet, karar, kaydet, kapat }: any) {
  return (
    <div style={{ position: "fixed", inset: 0, zIndex: 1000, background: "rgba(0,0,0,0.8)", display: "flex", alignItems: "center", justifyContent: "center", padding: "16px" }}>
      <div style={{ width: "100%", maxWidth: "620px", background: "#0a0f1a", border: "1px solid #1f2937", borderRadius: "28px", padding: "24px", overflowY: "auto", maxHeight: "90vh", color: "#fff" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: "20px" }}>
          <div>
            <p style={{ fontSize: "11px", fontWeight: 700, letterSpacing: "0.2em", color: "#a78bfa", textTransform: "uppercase", marginBottom: "6px" }}>Fiyat Kontrol</p>
            <h2 style={{ fontSize: "22px", fontWeight: 900 }}>Fiyat Kontrol Paneli</h2>
          </div>
          <button onClick={kapat} style={{ padding: "8px 16px", background: "#1f2937", border: "1px solid #374151", borderRadius: "12px", color: "#d1d5db", fontSize: "13px", cursor: "pointer" }}>Kapat</button>
        </div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: "10px", marginBottom: "20px" }}>
          {[
            { label: "Satış",   value: toplam, color: "#6ee7b7" },
            { label: "Maliyet", value: maliyet, color: "#f9fafb" },
            { label: `Kâr · %${Number(karYuzde).toFixed(1)}`, value: kar, color: "#fbbf24" },
          ].map((k) => (
            <div key={k.label} style={{ background: "#111827", border: "1px solid #1f2937", borderRadius: "16px", padding: "14px" }}>
              <p style={{ fontSize: "11px", color: "#6b7280", marginBottom: "6px" }}>{k.label}</p>
              <p style={{ fontSize: "16px", fontWeight: 900, color: k.color }}>{Number(k.value).toLocaleString("tr-TR", { minimumFractionDigits: 2 })} ₺</p>
            </div>
          ))}
        </div>
        <div style={{ border: "1px solid #1f2937", borderRadius: "16px", overflow: "hidden", marginBottom: "16px" }}>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 60px 60px 120px 100px", padding: "10px 14px", background: "#111827", fontSize: "11px", color: "#6b7280", fontWeight: 700 }}>
            <span>Kalem</span><span style={{ textAlign: "right" }}>Mtül</span><span style={{ textAlign: "right" }}>Kts</span><span style={{ textAlign: "right" }}>Birim</span><span style={{ textAlign: "right" }}>Toplam</span>
          </div>
          {satirlar.map((r: any) => (
            <div key={r.ad} style={{ display: "grid", gridTemplateColumns: "1fr 60px 60px 120px 100px", padding: "10px 14px", borderTop: "1px solid #1f2937", fontSize: "13px", alignItems: "center" }}>
              <span style={{ fontWeight: 600 }}>{r.ad}</span>
              <span style={{ textAlign: "right", color: "#9ca3af" }}>{r.mtul.toFixed(2)}</span>
              <span style={{ textAlign: "right", color: "#9ca3af" }}>{r.katsayi}</span>
              <div style={{ textAlign: "right" }}>
                <input
                  value={fiyatOverride[r.ad] ?? r.birim.toFixed(2)}
                  onChange={(e) => setFiyatOverride({ ...fiyatOverride, [r.ad]: Number(e.target.value || 0) })}
                  style={{ width: "80px", background: "#1f2937", border: "1px solid #374151", borderRadius: "8px", padding: "4px 8px", color: "#fff", textAlign: "right", fontSize: "13px", outline: "none" }}
                />
                <span style={{ fontSize: "11px", color: "#6b7280", marginLeft: "4px" }}>₺</span>
              </div>
              <span style={{ textAlign: "right", fontWeight: 700 }}>
                {((fiyatOverride[r.ad] ?? r.birim) * r.mtul).toLocaleString("tr-TR", { minimumFractionDigits: 2 })} ₺
              </span>
            </div>
          ))}
        </div>
        <button onClick={kaydet} style={{ width: "100%", padding: "14px", background: "#10b981", border: "none", borderRadius: "14px", color: "#fff", fontSize: "15px", fontWeight: 900, cursor: "pointer", marginBottom: "14px" }}>
          💾 Manuel Fiyatları Kaydet
        </button>
        <div style={{ background: "#111827", border: "1px solid #1f2937", borderRadius: "16px", padding: "16px" }}>
          <p style={{ fontSize: "16px", fontWeight: 700, color: karar.renk, marginBottom: "6px" }}>{karar.baslik}</p>
          <p style={{ fontSize: "13px", color: "#9ca3af" }}>{karar.metin}</p>
        </div>
      </div>
    </div>
  );
}
