                "davlumbaz":"davlumbaz","süpürgelik":"süpürgelik",
              };
              const rows = parcalar
                .filter((p: any) => Number(p?.boyCm || 0) > 0 && Number(p?.enCm || 0) > 0)
                .map((p: any) => {
                  const raw = String(p?.standartTip || p?.etiket || "tezgah").toLowerCase().trim();
