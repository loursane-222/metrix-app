                "l dönüş tezgah":30,"l tezgah arası":20,"ön alın":8,"l ön alın":10,
                "ada tezgah":30,"ada ayak":18,"ada iç dönüş":18,"ada dış dönüş":18,
                "davlumbaz":15,"tezgah ayak":18,"süpürgelik":5,
              };
              const PART_MAP: Record<string,string> = {
                "tezgah":"tezgah","tezgah_arasi":"tezgah arası","tezgah arası":"tezgah arası",
                "ada_tezgah":"ada tezgah","ada tezgah":"ada tezgah",
                "ada_ayak":"ada ayak","on_alin":"ön alın","ön alın":"ön alın",
                "stres_alma":"stres alma","stres alma":"stres alma",
