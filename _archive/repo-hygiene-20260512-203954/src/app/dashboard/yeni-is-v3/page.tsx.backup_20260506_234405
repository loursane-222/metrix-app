                <WInput label="Plaka Fiyatı €"      value={form.plakaFiyatiEuro}    onChange={(v: string) => setAlan("plakaFiyatiEuro", v)} />
                <WInput label="Kur (₺/€)"           value={form.kullanilanKur}      onChange={(v: string) => setAlan("kullanilanKur", v)} />
                <WInput label="Plaka Sayısı"         value={form.manuelPlakaSayisi}  onChange={(v: string) => setAlan("manuelPlakaSayisi", v)} />
                <WInput label="Plaka Genişlik cm"    value={form.plakaGenislikCm}    onChange={(v: string) => setAlan("plakaGenislikCm", v)} />
                <WInput label="Plaka Yükseklik cm"   value={form.plakaUzunlukCm}     onChange={(v: string) => setAlan("plakaUzunlukCm", v)} />
                <WInput label="Plakadan Alınan Mtül" value={form.plakadanAlinanMtul} onChange={(v: string) => setAlan("plakadanAlinanMtul", v)} />
              </div>
              {hesap.malzeme > 0 && (
                <div className="rounded-xl border border-slate-700 bg-[#111827] p-4">
                  <p className="text-xs text-slate-400 mb-1">Malzeme Maliyeti</p>
                  <p className="text-2xl font-black">{para(hesap.malzeme)}</p>
                  <p className="text-xs text-slate-500 mt-1">{hesap.plakaSayisi} plaka × {form.plakaFiyatiEuro}€ × {form.kullanilanKur}₺</p>
                </div>
              )}
              <div className="hidden md:flex justify-end pt-2">
                <button onClick={() => sonrakiAdim && setAktifAdim(sonrakiAdim)}
                  className="rounded-2xl bg-blue-600 hover:bg-blue-500 px-8 py-4 text-sm font-black text-white transition">
                  İleri →
                </button>
              </div>
            </div>
          )}

          {/* ADIM 3 — Ölçüler */}
          {aktifAdim === "olculer" && (
            <div className="space-y-5">
              <div>
                <h2 className="text-xl font-black">Maliyet ve Üretim</h2>
                <p className="text-sm text-slate-400 mt-1">İşçilik ölçülerini ve sürelerini gir</p>
              </div>
              <div className="grid grid-cols-1 gap-2">
                {[
                  { label:"Tezgah",               mtulKey:"metrajMtul",      makineKey:"tezgahMakineId",        dakikaKey:"birMtulDakika"      },
                  { label:"Tezgah Arası",          mtulKey:"tezgahArasiMtul", makineKey:"tezgahArasiMakineId",   dakikaKey:"tezgahArasiDakika"  },
                  { label:"Ada",                   mtulKey:"adaTezgahMtul",   makineKey:"adaMakineId",            dakikaKey:"adaTezgahDakika"    },
                  { label:"Stres Alma",            mtulKey:"ozelIscilik1Mtul",makineKey:"stresAlmaMakineId",     dakikaKey:"ozelIscilik1Dakika" },
                  { label:"Fason Ebatlama",        mtulKey:"ozelIscilik2Mtul",makineKey:"fasonEbatlamaMakineId", dakikaKey:"ozelIscilik2Dakika" },
                  { label:"45 Kesim",              mtulKey:"kesim45Mtul",     makineKey:"kesim45MakineId",        dakikaKey:"kesim45Dakika"      },
                  { label:"Pahlama",               mtulKey:"pahlamaMtul",     makineKey:"pahlamaMakineId",        dakikaKey:"pahlamaDakika"      },
                  { label:"Yapıştırma / Toplama",  mtulKey:"yapistirmaMtul",  makineKey:"yapistirmaMakineId",     dakikaKey:"yapistirmaDakika"   },
                ].map((row) => (
                  <OperationRow key={row.label} label={row.label}
                    mtul={(form as any)[row.mtulKey]}     setMtul={(v: string)   => setAlan(row.mtulKey, v)}
                    makine={(form as any)[row.makineKey]} setMakine={(v: string) => setAlan(row.makineKey, v)}
                    dakika={(form as any)[row.dakikaKey]} setDakika={(v: string) => setAlan(row.dakikaKey, v)}
                    makineler={makineler} />
                ))}
              </div>
              <div className="grid grid-cols-2 gap-4">
                <WInput label="Kâr %" value={form.karYuzdesi} onChange={(v: string) => setAlan("karYuzdesi", v)} />
                <div />
              </div>
              <div className="hidden md:flex justify-end pt-2">
                <button onClick={() => sonrakiAdim && setAktifAdim(sonrakiAdim)}
                  className="rounded-2xl bg-blue-600 hover:bg-blue-500 px-8 py-4 text-sm font-black text-white transition">
                  İleri →
                </button>
              </div>
            </div>
          )}

          {/* ADIM 4 — Özet */}
          {aktifAdim === "ozet" && (
            <div className="space-y-6">
              <div>
                <h2 className="text-xl font-black">Özet & Kaydet</h2>
                <p className="text-sm text-slate-400 mt-1">Son kontrol yap, kaydet</p>
              </div>
              <div className="rounded-xl border border-slate-700 bg-[#0B1120] divide-y divide-slate-800">
                <OzetSatir label="Müşteri"      value={form.musteriAdi || "—"} />
                <OzetSatir label="Ürün / Taş"   value={form.urunAdi    || "—"} />
                <OzetSatir label="Malzeme Tipi" value={form.malzemeTipi} />
                <OzetSatir label="Müşteri Tipi" value={form.musteriTipi} />
                <OzetSatir label="Tarih"        value={form.isTarihi} />
              </div>
              <div className="grid grid-cols-2 gap-3">
                <div className="col-span-2 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-5">
                  <p className="text-xs text-slate-400">Teklif Tutarı</p>
                  <p className="text-3xl font-black text-emerald-400 mt-1">{para(hesap.satis)}</p>
                </div>
                <OzetKart label="Toplam Maliyet" value={para(hesap.maliyet)} />
                <OzetKart label="Kâr"            value={para(hesap.kar)}    color="text-yellow-400" />
                <OzetKart label="Malzeme"        value={para(hesap.malzeme)} />
                <OzetKart label="İşçilik"        value={para(hesap.iscilik)} />
                <OzetKart label="Plaka Sayısı"   value={`${hesap.plakaSayisi} adet`} />
                <OzetKart label="Üretim Süresi"  value={`${hesap.toplamDakika.toFixed(0)} dk`} />
              </div>

              {/* Birim satış fiyatları — fiyatAnaliziSatirlari() ile aynı mantık */}
              {hesap.satis > 0 && fiyatAnaliziSatirlari().length > 0 && (
                <div>
                  <p className="text-xs text-slate-400 mb-2">Müşteriye Verilen Birim Fiyatlar</p>
                  <div className="rounded-xl border border-slate-700 bg-[#0B1120] divide-y divide-slate-800">
                    {fiyatAnaliziSatirlari().map((r) => (
                      <OzetSatir key={r.ad} label={r.ad} value={`${para(r.birim)} / mtül`} />
                    ))}
                    {hesap.plakaSayisi > 0 && n(form.plakaFiyatiEuro) > 0 && (
                      <OzetSatir label="Plaka birim" value={`${form.plakaFiyatiEuro}€ × ${form.kullanilanKur}₺ = ${para(n(form.plakaFiyatiEuro) * n(form.kullanilanKur))} / plaka`} />
                    )}
                  </div>
                </div>
              )}
              <div className="hidden">
              </div>
              <div>
                <p className="text-xs text-slate-400 mb-2">Notlar</p>
                <textarea value={form.notlar} onChange={(e) => setAlan("notlar", e.target.value)}
                  className="w-full h-[120px] rounded-xl bg-[#111827] border border-slate-700 p-4 outline-none text-sm resize-none"
                  placeholder="Özel notlar..." />
              </div>
              <div className="hidden md:flex gap-3">
                {oncekiAdim && (
                  <button onClick={() => setAktifAdim(oncekiAdim)}
                    className="rounded-2xl border border-slate-700 px-6 py-4 text-sm font-bold text-slate-300 hover:bg-slate-800 transition">
                    ← Geri
                  </button>
                )}
                <button onClick={kaydet} disabled={kaydediliyor}
                  className="flex-1 rounded-2xl bg-emerald-600 hover:bg-emerald-500 disabled:bg-slate-700 px-6 py-5 text-lg font-black text-white shadow-[0_18px_40px_rgba(16,185,129,0.3)] transition">
                  {kaydediliyor ? "Kaydediliyor..." : "✓ Hesapla & Kaydet"}
                </button>
              </div>
            </div>
          )}
        </div>

        {/* Mobil alt nav */}
        <div className="md:hidden fixed bottom-0 left-0 right-0 z-[1200] pointer-events-none px-4 pb-[calc(env(safe-area-inset-bottom)+12px)]">
          <div className="flex items-center justify-between gap-3">
            <button type="button"
              onClick={() => oncekiAdim ? setAktifAdim(oncekiAdim) : router.push("/dashboard/isler")}
              className="pointer-events-auto rounded-2xl border border-slate-700 bg-slate-950/95 px-5 py-4 text-sm font-bold text-slate-200 shadow-2xl backdrop-blur-xl">
              {oncekiAdim ? "← Geri" : "← İşlere Dön"}
            </button>
            {sonrakiAdim ? (
              <button type="button" onClick={() => setAktifAdim(sonrakiAdim)}
                className="pointer-events-auto ml-auto rounded-2xl bg-blue-600 px-8 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,99,235,0.45)]">
                İleri →
              </button>
            ) : (
              <button type="button" onClick={kaydet} disabled={kaydediliyor}
                className="pointer-events-auto ml-auto rounded-2xl bg-emerald-600 px-6 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(16,185,129,0.36)] disabled:bg-slate-700">
                {kaydediliyor ? "Kaydediliyor..." : "✓ Kaydet"}
              </button>
            )}
          </div>
        </div>
      </main>

      {/* Plaka Planlayıcı Modal */}
      {plakaAcik && (
        <div className="fixed inset-0 z-[100] bg-black/80 flex items-center justify-center p-0 md:p-4" onClick={() => setPlakaAcik(false)}>
          <div className="plaka-v2-fix h-[100dvh] w-full overflow-y-auto rounded-none bg-[#030712] p-3 pb-[calc(env(safe-area-inset-bottom)+90px)] md:h-[95vh] md:w-[95vw] md:rounded-2xl md:p-4"
            onClick={(e) => e.stopPropagation()}>
            <div className="sticky top-0 z-30 mb-4 flex items-start justify-between gap-3 border-b border-slate-800 bg-[#030712]/95 pb-3 pt-[env(safe-area-inset-top)] backdrop-blur-xl">
              <div>
                <h2 className="text-xl font-black">Plaka Planlayıcı</h2>
                <p className="text-sm text-slate-400">Ürün, ölçü ve fiyat bilgileri aktarıldı.</p>
              </div>
              <button onClick={() => setPlakaAcik(false)} className="shrink-0 rounded-xl border border-slate-700 px-4 py-2 text-sm">Kapat</button>
            </div>
            <PlakaPlanlayiciV2 embedded
              initialProductName={form.urunAdi} initialPlakaGenislik={form.plakaGenislikCm}
              initialPlakaYukseklik={form.plakaUzunlukCm} initialPlakaFiyati={form.plakaFiyatiEuro}
              initialRows={plakaInitialRows}
              onApply={aiAktar} />
          </div>
        </div>
      )}
    </div>
  );
}

// ── Fiyat Kontrol Paneli ──────────────────────────────────────────────────────
function FiyatPanelModal({ fiyatAnaliziSatirlari, fiyatOverride, setFiyatOverride,
  fiyatPanelToplam, fiyatPanelKar, fiyatPanelKarYuzde, hesapMaliyet,
  fiyatKarari, manuelFiyatlariKaydet, onKapat }: any) {
  return (
    <div className="fixed inset-0 z-[1000] flex items-center justify-center bg-black/80 p-4">
      <div className="w-full max-w-3xl rounded-[32px] border border-slate-700 bg-[#0B1120] p-6 text-white shadow-2xl overflow-y-auto max-h-[90vh]">
        <div className="mb-5 flex items-start justify-between gap-4">
          <div>
            <p className="text-xs font-bold uppercase tracking-[0.25em] text-purple-300">Fiyat Kontrol</p>
            <h2 className="mt-2 text-2xl font-black">Fiyat Kontrol Paneli</h2>
          </div>
          <button type="button" onClick={onKapat} className="rounded-xl border border-slate-700 px-4 py-2 text-sm shrink-0">Kapat</button>
        </div>
        <div className="mb-5 grid gap-3 md:grid-cols-3">
          {[
            { label:"Satış",   value:fiyatPanelToplam,  color:"text-emerald-300" },
            { label:"Maliyet", value:hesapMaliyet,       color:"text-white"       },
            { label:"Kâr",     value:fiyatPanelKar,     color:"text-amber-300",  extra:`· %${Number(fiyatPanelKarYuzde).toFixed(1)}` },
          ].map(({ label, value, color, extra }) => (
            <div key={label} className="rounded-2xl border border-slate-700 bg-slate-900 p-4">
              <p className="text-xs text-slate-400">{label}</p>
              <p className={`mt-2 text-xl font-black ${color}`}>
                {Number(value).toLocaleString("tr-TR",{minimumFractionDigits:2})} ₺ {extra || ""}
              </p>
            </div>
          ))}
        </div>
        <div className="overflow-hidden rounded-2xl border border-slate-700">
          <table className="w-full text-sm">
            <thead className="bg-slate-900 text-slate-400">
              <tr>
                <th className="p-3 text-left">Kalem</th>
                <th className="p-3 text-right">Mtül</th>
                <th className="p-3 text-right">Katsayı</th>
                <th className="p-3 text-right">Birim</th>
                <th className="p-3 text-right">Toplam</th>
              </tr>
            </thead>
            <tbody>
              {fiyatAnaliziSatirlari.map((r: any) => (
                <tr key={r.ad} className="border-t border-slate-800">
                  <td className="p-3 font-semibold">{r.ad}</td>
                  <td className="p-3 text-right">{r.mtul.toFixed(2)}</td>
                  <td className="p-3 text-right">{r.katsayi}</td>
                  <td className="p-3 text-right">
                    <input value={fiyatOverride[r.ad] ?? r.birim.toFixed(2)}
                      onChange={(e) => setFiyatOverride({ ...fiyatOverride, [r.ad]: Number(e.target.value||0) })}
                      className="w-28 rounded bg-slate-800 px-2 py-1 text-right text-white" />
                    <span className="ml-1 text-xs text-slate-400">₺</span>
                  </td>
                  <td className="p-3 text-right font-bold">
                    {((fiyatOverride[r.ad] ?? r.birim) * r.mtul).toLocaleString("tr-TR",{minimumFractionDigits:2})} ₺
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div className="mt-5">
          <button type="button" onClick={manuelFiyatlariKaydet}
            className="w-full rounded-2xl bg-emerald-600 px-5 py-4 text-sm font-black text-white hover:bg-emerald-500">
            💾 Manuel Fiyatları Kaydet
          </button>
        </div>
        <div className="mt-5 rounded-2xl border border-slate-700 bg-slate-900 p-5">
          <p className={`text-lg font-black ${fiyatKarari.renk}`}>{fiyatKarari.baslik}</p>
          <p className="mt-2 text-sm text-slate-300">{fiyatKarari.metin}</p>
        </div>
      </div>
    </div>
  );
}

// ── Alt bileşenler ────────────────────────────────────────────────────────────
function OperationRow({ label, mtul, setMtul, makine, setMakine, dakika, setDakika, makineler }: any) {
  return (
    <div className="grid grid-cols-1 md:grid-cols-[1fr_1.2fr_0.75fr] gap-2 items-end rounded-xl border border-slate-800 bg-[#111827]/60 px-2.5 py-2">
      <label className="block">
        <p className="text-[10px] text-slate-400 mb-1">{label} Mtül</p>
        <input value={mtul} onChange={(e) => setMtul(e.target.value)}
          onBlur={(e) => setMtul(normalizeMtulDisplay(e.target.value))}
          className="w-full h-10 rounded-lg bg-[#0B1120] border border-slate-700 px-3 text-sm outline-none focus:border-blue-500" />
      </label>
      <label className="block min-w-0">
        <p className="text-[10px] text-slate-400 mb-1">Makine</p>
        <select value={makine} onChange={(e) => setMakine(e.target.value)}
          className="w-full h-10 rounded-lg bg-[#0B1120] border border-slate-700 px-2 text-[11px] outline-none focus:border-blue-500 truncate">
          {makineler.length === 0 && <option value="">Makine yok</option>}
          {makineler.map((m: any) => (
            <option key={m.id} value={m.id}>
              {m.makineAdi} · {Number(m.dakikalikMaliyet??m.dkMaliyet??m.dakikaMaliyet??m.hesaplananDakikaMaliyeti??m.minuteCost??0).toFixed(2)}₺/dk
            </option>
          ))}
        </select>
      </label>
      <label className="block">
        <p className="text-[10px] text-slate-400 mb-1">Süre dk/mtül</p>
        <input value={dakika} onChange={(e) => setDakika(e.target.value)}
          className="w-full h-10 rounded-lg bg-[#0B1120] border border-slate-700 px-3 text-sm outline-none focus:border-blue-500" />
      </label>
    </div>
  );
}
function WInput({ label, value, onChange, type = "text" }: any) {
  return (
    <label className="block">
      <p className="text-xs text-slate-400 mb-2">{label}</p>
      <input type={type} value={value} onChange={(e) => onChange(e.target.value)}
        className="w-full rounded-xl bg-[#111827] border border-slate-700 px-4 py-3 outline-none focus:border-blue-500 text-base" />
    </label>
  );
}
function WSelect({ label, value, onChange, options }: any) {
  return (
    <label className="block">
      <p className="text-xs text-slate-400 mb-2">{label}</p>
      <select value={value} onChange={(e) => onChange(e.target.value)}
        className="w-full rounded-xl bg-[#111827] border border-slate-700 px-4 py-3 outline-none focus:border-blue-500 text-base">
        {options.map((o: string) => <option key={o} value={o}>{o}</option>)}
      </select>
    </label>
  );
}
function SummaryCard({ label, value, color = "text-white" }: any) {
  return (
    <div className="flex items-center justify-between py-1.5">
      <p className="text-xs text-slate-500">{label}</p>
      <p className={`text-sm font-bold ${color}`}>{value}</p>
    </div>
  );
}
function OzetSatir({ label, value }: any) {
  return (
    <div className="flex items-center justify-between px-4 py-3 gap-4">
      <p className="text-xs text-slate-400 shrink-0">{label}</p>
      <p className="text-sm font-semibold text-right truncate">{value}</p>
    </div>
  );
}
function OzetKart({ label, value, color = "text-white" }: any) {
  return (
    <div className="bg-[#111827] border border-slate-800 rounded-xl p-4">
      <p className="text-xs text-slate-400">{label}</p>
      <p className={`text-lg font-black mt-1 ${color}`}>{value}</p>
    </div>
  );
}
