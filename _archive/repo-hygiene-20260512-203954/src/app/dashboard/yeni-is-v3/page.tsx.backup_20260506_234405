"use client";

import { normalizeMtulDisplay } from "@/lib/normalizeMtul";
import { useEffect, useMemo, useState, useRef } from "react";
import { useRouter } from "next/navigation";
import { PlakaPlanlayiciV2 } from "@/components/plaka-planlayici/PlakaPlanlayiciV2";
import AiYeniIsPanel from "@/components/ai/AiYeniIsPanel";

function tl(v: any) {
  return Number(v || 0).toLocaleString("tr-TR", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " ₺";
}
function n(v: string | number) {
  const x = Number(String(v || "0").replace(",", "."));
  return Number.isFinite(x) ? x : 0;
}
function para(v: number) {
  return v.toLocaleString("tr-TR", { maximumFractionDigits: 2 }) + " ₺";
}

const TASLAK_KEY = "metrix_yeni_is_taslak";

const ADIMLAR = [
  { id: "musteri", label: "Müşteri",  kisaLabel: "Müşteri"  },
  { id: "malzeme", label: "Malzeme",  kisaLabel: "Malzeme"  },
  { id: "olculer", label: "Ölçüler",  kisaLabel: "Ölçüler"  },
  { id: "ozet",    label: "Özet",     kisaLabel: "Özet"     },
] as const;

type AdimId = typeof ADIMLAR[number]["id"];

export default function YeniIsV3Page() {
  const router = useRouter();

  const [aktifAdim, setAktifAdim]               = useState<AdimId>("musteri");
  const [plakaAcik, setPlakaAcik]               = useState(false);
  const [kaydediliyor, setKaydediliyor]         = useState(false);
  const [basariEkrani, setBasariEkrani]         = useState(false);
  const [yeniMusteriOlusturuldu, setYeniMusteriOlusturuldu] = useState(false);
  const [sonKayitTeklifNo, setSonKayitTeklifNo] = useState("");
  const [sonKayitIsId, setSonKayitIsId]         = useState("");
  const [fiyatPanelAcik, setFiyatPanelAcik]    = useState(false);
  const [fiyatOverride, setFiyatOverride]       = useState<any>({});
  const [musteriler, setMusteriler]             = useState<any[]>([]);
  const [makineler, setMakineler]               = useState<any[]>([]);
  const [musteriListeAcik, setMusteriListeAcik] = useState(false);
  const [aiMode, setAiMode]                     = useState(true);
  const [taslakKaydedildi, setTaslakKaydedildi]= useState(false);
  const [plakaInitialRows, setPlakaInitialRows]   = useState<any[]>([]);
  const mainRef      = useRef<HTMLDivElement>(null);
  const taslakTimer  = useRef<any>(null);

  // Layout scroll override — wizard kendi scroll'unu yönetir
  useEffect(() => {
    const main  = document.getElementById("dashboard-main");
    const inner = document.getElementById("dashboard-inner");
    const origMainStyle  = main?.getAttribute("style")  || "";
    const origInnerStyle = inner?.getAttribute("style") || "";
    if (main)  { main.style.overflow  = "hidden"; main.style.height  = "100dvh"; main.style.minHeight = "unset"; main.style.paddingBottom = "0"; }
    if (inner) { inner.style.overflow = "hidden"; inner.style.height = "100dvh"; inner.style.minHeight = "unset"; }
    return () => {
      if (main)  main.setAttribute("style", origMainStyle);
      if (inner) inner.setAttribute("style", origInnerStyle);
    };
  }, []);

  const [form, setForm] = useState({
    musteriId: "", musteriAdi: "", urunAdi: "", malzemeTipi: "Porselen",
    musteriTipi: "Ev sahibi", isTarihi: new Date().toISOString().slice(0, 10),
    kullanilanKur: "53", karYuzdesi: "30",
    plakaFiyatiEuro: "", plakaGenislikCm: "", plakaUzunlukCm: "",
    manuelPlakaSayisi: "", plakaLayoutJson: null as any, plakaImageUrl: "",
    plakadanAlinanMtul: "5", metrajMtul: "", birMtulDakika: "25",
    tezgahArasiMtul: "", tezgahArasiDakika: "18", adaTezgahMtul: "", adaTezgahDakika: "30",
    ozelIscilik1Mtul: "", ozelIscilik1Dakika: "", ozelIscilik2Mtul: "", ozelIscilik2Dakika: "",
    ozelIscilik3Mtul: "", ozelIscilik3Dakika: "",
    tezgahMakineId: "", tezgahArasiMakineId: "", adaMakineId: "",
    stresAlmaMakineId: "", fasonEbatlamaMakineId: "",
    kesim45Mtul: "", kesim45Dakika: "4", kesim45MakineId: "",
    pahlamaMtul: "", pahlamaDakika: "1", pahlamaMakineId: "",
    yapistirmaMtul: "", yapistirmaDakika: "8", yapistirmaMakineId: "",
    notlar: "", tasDurumu: "",
  });

  useEffect(() => {
    try {
      const url = new URL(window.location.href);
      const fresh = url.searchParams.get("fresh") === "1";
      if (fresh) {
        // Yeni iş — taslağı temizle, AI modunda başla
        localStorage.removeItem(TASLAK_KEY);
        return;
      }
      const ham = localStorage.getItem(TASLAK_KEY);
      if (ham) {
        const t = JSON.parse(ham);
        if (t?.musteriAdi || t?.urunAdi) {
          setForm((p) => ({ ...p, ...t }));
          setAiMode(false);
        }
      }
    } catch {}
  }, []);

  useEffect(() => {
    clearTimeout(taslakTimer.current);
    taslakTimer.current = setTimeout(() => {
      try {
        localStorage.setItem(TASLAK_KEY, JSON.stringify(form));
        setTaslakKaydedildi(true);
        setTimeout(() => setTaslakKaydedildi(false), 1500);
      } catch {}
    }, 1200);
    return () => clearTimeout(taslakTimer.current);
  }, [form]);

  useEffect(() => {
    mainRef.current?.scrollTo({ top: 0, behavior: "smooth" });
    window.scrollTo(0, 0);
  }, [aktifAdim]);

  useEffect(() => {
    fetch("/api/musteriler-lite").then((r) => r.json()).then((v) => setMusteriler(v.musteriler || []));
    fetch("/api/makineler-lite").then((r) => r.json()).then((v) => {
      const liste = v.makineler || [];
      setMakineler(liste);
      if (liste.length > 0) {
        setForm((p) => ({
          ...p,
          tezgahMakineId:        p.tezgahMakineId        || liste[0].id,
          tezgahArasiMakineId:   p.tezgahArasiMakineId   || liste[0].id,
          adaMakineId:           p.adaMakineId            || liste[0].id,
          stresAlmaMakineId:     p.stresAlmaMakineId      || liste[0].id,
          fasonEbatlamaMakineId: p.fasonEbatlamaMakineId  || liste[0].id,
          kesim45MakineId:       p.kesim45MakineId        || liste[0].id,
          pahlamaMakineId:       p.pahlamaMakineId        || liste[0].id,
          yapistirmaMakineId:    p.yapistirmaMakineId     || liste[0].id,
        }));
      }
    });
  }, []);

  function setAlan(key: string, value: string) { setForm((p) => ({ ...p, [key]: value })); }
  function musteriSec(m: any) {
    const tipMap: Record<string, string> = {
      bayi: 'Bayi', mimar: 'Mimar', son_kullanici: 'Ev sahibi', muteahhit: 'Müteahhit'
    }
    const musteriAdiStr = [m.firmaAdi, m.ad, m.soyad].filter(Boolean).join(' ') || m.ad || ''
    const yeniTip = m.musteriTipi ? (tipMap[m.musteriTipi] || 'Ev sahibi') : undefined
    setForm((p) => ({
      ...p,
      musteriId: m.id,
      musteriAdi: musteriAdiStr,
      ...(yeniTip ? { musteriTipi: yeniTip } : {})
    }))
    setMusteriListeAcik(false)
  }
  function taslakSil() { try { localStorage.removeItem(TASLAK_KEY); } catch {} }

  function makineMaliyet(id: string) {
    const m = makineler.find((x) => x.id === id);
    if (!m) return 0;
    return Number(m.dakikalikMaliyet ?? m.dkMaliyet ?? m.dakikaMaliyet ?? m.hesaplananDakikaMaliyeti ?? m.minuteCost ?? m.costPerMinute ?? 0) || 0;
  }

  function aiAktar(sonuc: any) {
    // PlakaPlanlayiciV2 direkt AIPlakaAktarSonucu döndürür (sonuc.sonuc wrapper yok)
    // AiYeniIsPanel ise sonuc.sonuc içinde verir
    const isPlakaAktar = sonuc?.plakaLayoutJson != null && sonuc?.tezgahMtul != null;
    const data        = isPlakaAktar ? {} : (sonuc?.sonuc || sonuc || {});
    const malzeme     = data?.malzeme || {};
    const isBilgisi   = data?.isBilgisi || {};
    const musteriAi   = data?.musteri || {};
    const parcalar    = Array.isArray(data?.parcalar)     ? data.parcalar     : [];
    const operasyonlar= Array.isArray(data?.operasyonlar) ? data.operasyonlar : [];

    const sumMtul = (tipler: string[]) =>
      parcalar.filter((p: any) => tipler.includes(String(p?.standartTip || ""))).reduce((acc: number, p: any) => {
        const mtul = Number(p?.mtul || 0);
        const boydan = Number(p?.boyCm || 0) > 0 ? Number(p.boyCm) / 100 : 0;
        const adet = Number(p?.adet || 1) || 1;
        return acc + (mtul > 0 ? mtul : boydan * adet);
      }, 0);

    const normalizeOpTip = (v: any) => {
      const t = String(v || "").toLocaleLowerCase("tr-TR").trim()
        .replace(/ı/g,"i").replace(/ş/g,"s").replace(/ğ/g,"g")
        .replace(/ü/g,"u").replace(/ö/g,"o").replace(/ç/g,"c").replace(/\s+/g,"_");
      if (t.includes("45") || t.includes("kesim_45")) return "kesim_45";
      if (t.includes("pahlama"))                      return "pahlama";
      if (t.includes("yapistirma") || t.includes("toplama")) return "yapistirma";
      if (t.includes("stres"))                        return "stres_alma";
      if (t.includes("fason"))                        return "fason_ebatlama";
      return t;
    };
    const opMtul = (o: any) => {
      const direct = Number(o?.mtul || 0);
      if (direct > 0) return direct;
      const kaynak = `${o?.etiket || ""} ${o?.detay || ""}`;
      const match  = kaynak.match(/(\d+(?:[\.,]\d+)?)/);
      if (!match) return 0;
      const nv = Number(String(match[1]).replace(",", "."));
      if (!Number.isFinite(nv) || nv <= 0) return 0;
      return nv > 20 ? nv / 100 : nv;
    };
    const sumOpMtul = (tipler: string[]) =>
      operasyonlar.filter((o: any) => tipler.includes(normalizeOpTip(o?.tip || o?.etiket))).reduce((acc: number, o: any) => acc + opMtul(o), 0);

    const musteriAdi = musteriAi?.ad || isBilgisi?.musteriAdi || "";
    const eslesenMusteri = musteriler.find((m) =>
      String(m.ad || "").trim().toLocaleLowerCase("tr-TR") === String(musteriAdi || "").trim().toLocaleLowerCase("tr-TR")
    );

    setForm((p) => ({
      ...p,
      musteriId:         eslesenMusteri?.id || "",
      musteriAdi:        musteriAdi || p.musteriAdi,
      urunAdi:           malzeme?.urunAdi || [malzeme?.marka, malzeme?.seri, malzeme?.renk].filter(Boolean).join(" ") || p.urunAdi,
      kullanilanKur:     malzeme?.kur ? String(malzeme.kur) : p.kullanilanKur,
      plakaFiyatiEuro:   isPlakaAktar && (sonuc.ortalamaPlakaFiyati||0) > 0 ? String(Number(sonuc.ortalamaPlakaFiyati).toFixed(2))
                         : malzeme?.plakaFiyatiEuro ? String(malzeme.plakaFiyatiEuro) : p.plakaFiyatiEuro,
      plakaGenislikCm:   malzeme?.plakaOlcusu?.enCm ? String(Math.max(Number(malzeme.plakaOlcusu.enCm||0), Number(malzeme.plakaOlcusu.boyCm||0))) : p.plakaGenislikCm,
      plakaUzunlukCm:    malzeme?.plakaOlcusu?.boyCm ? String(Math.min(Number(malzeme.plakaOlcusu.enCm||0), Number(malzeme.plakaOlcusu.boyCm||0))) : p.plakaUzunlukCm,
      manuelPlakaSayisi: sonuc?.plakaLayoutJson?.plakaSayisi ? String(sonuc.plakaLayoutJson.plakaSayisi) : p.manuelPlakaSayisi,
      plakaLayoutJson:   sonuc?.plakaLayoutJson  || p.plakaLayoutJson  || null,
      plakaImageUrl:     sonuc?.plakaImageUrl    || p.plakaImageUrl    || "",
      metrajMtul:        isPlakaAktar && (sonuc.tezgahMtul||0) > 0 ? String(Number(sonuc.tezgahMtul).toFixed(2))
                         : sumMtul(["tezgah"]) > 0 ? String(sumMtul(["tezgah"]).toFixed(2)) : p.metrajMtul,
      tezgahArasiMtul:   isPlakaAktar && (sonuc.tezgahArasiMtul||0) > 0 ? String(Number(sonuc.tezgahArasiMtul).toFixed(2))
                         : sumMtul(["tezgah_arasi"]) > 0 ? String(sumMtul(["tezgah_arasi"]).toFixed(2)) : p.tezgahArasiMtul,
      adaTezgahMtul:     isPlakaAktar && (sonuc.adaTezgahMtul||0) > 0 ? String(Number(sonuc.adaTezgahMtul).toFixed(2))
                         : sumMtul(["ada_tezgah","ada_ayak"]) > 0 ? String(sumMtul(["ada_tezgah","ada_ayak"]).toFixed(2)) : p.adaTezgahMtul,
      ozelIscilik1Mtul:  isPlakaAktar && (sonuc.stresAlmaMtul||0) > 0 ? String(Number(sonuc.stresAlmaMtul).toFixed(2)) : p.ozelIscilik1Mtul,
      ozelIscilik2Mtul:  isPlakaAktar && (sonuc.fasonEbatlamaMtul||0) > 0 ? String(Number(sonuc.fasonEbatlamaMtul).toFixed(2)) : p.ozelIscilik2Mtul,
      kesim45Mtul:       sumOpMtul(["kesim_45","45_kesim"]) > 0 ? String(sumOpMtul(["kesim_45","45_kesim"]).toFixed(2)) : p.kesim45Mtul,
      pahlamaMtul:       sumOpMtul(["pahlama"]) > 0 ? String(sumOpMtul(["pahlama"]).toFixed(2)) : p.pahlamaMtul,
      yapistirmaMtul:    sumOpMtul(["yapistirma"]) > 0 ? String(sumOpMtul(["yapistirma"]).toFixed(2)) : p.yapistirmaMtul,
      notlar: [
        p.notlar,
        musteriAi?.tip === "yeni"  ? `AI: "${musteriAdi}" yeni müşteri olarak belirtildi.` : "",
        data?.uyarilar?.length     ? `AI uyarıları: ${data.uyarilar.join(" | ")}`           : "",
        data?.eksikSorular?.length ? `AI eksik: ${data.eksikSorular.join(" | ")}`           : "",
      ].filter(Boolean).join("\n"),
    }));
    setPlakaAcik(false);
    setAiMode(false);
    setAktifAdim(isPlakaAktar ? "olculer" : "malzeme");
  }

  const hesap = useMemo(() => {
    const toplamMtul = n(form.metrajMtul) + n(form.tezgahArasiMtul) + n(form.adaTezgahMtul) +
      n(form.ozelIscilik1Mtul) + n(form.ozelIscilik2Mtul) + n(form.ozelIscilik3Mtul);
    const tezgahDk       = n(form.metrajMtul)       * n(form.birMtulDakika);
    const tezgahArasiDk  = n(form.tezgahArasiMtul)  * n(form.tezgahArasiDakika);
    const adaDk          = n(form.adaTezgahMtul)    * n(form.adaTezgahDakika);
    const stresAlmaDk    = n(form.ozelIscilik1Mtul) * n(form.ozelIscilik1Dakika);
    const fasonDk        = n(form.ozelIscilik2Mtul) * n(form.ozelIscilik2Dakika);
    const kesim45Dk      = n(form.kesim45Mtul)      * n(form.kesim45Dakika);
    const pahlamaDk      = n(form.pahlamaMtul)      * n(form.pahlamaDakika);
    const yapistirmaDk   = n(form.yapistirmaMtul)   * n(form.yapistirmaDakika);
    const toplamDakika   = tezgahDk + tezgahArasiDk + adaDk + stresAlmaDk + fasonDk + kesim45Dk + pahlamaDk + yapistirmaDk;
    const plakaSayisi    =
      form.plakaLayoutJson?.plakaSayisi > 0 ? Number(form.plakaLayoutJson.plakaSayisi)
      : n(form.manuelPlakaSayisi) > 0       ? n(form.manuelPlakaSayisi)
      : n(form.plakadanAlinanMtul) > 0      ? Math.ceil(toplamMtul / n(form.plakadanAlinanMtul))
      : 0;
    const malzeme        = plakaSayisi * n(form.plakaFiyatiEuro) * n(form.kullanilanKur);
    const fb             = (id: string) => makineMaliyet(id) || 106.16;
    const tezgahMaliyet     = tezgahDk      * fb(form.tezgahMakineId);
    const tezgahArasiMaliyet= tezgahArasiDk * fb(form.tezgahArasiMakineId);
    const adaMaliyet        = adaDk         * fb(form.adaMakineId);
    const stresAlmaMaliyet  = stresAlmaDk   * fb(form.stresAlmaMakineId);
    const fasonMaliyet      = fasonDk       * fb(form.fasonEbatlamaMakineId);
    const kesim45Maliyet    = kesim45Dk     * fb(form.kesim45MakineId);
    const iscilik = tezgahMaliyet + tezgahArasiMaliyet + adaMaliyet + stresAlmaMaliyet + fasonMaliyet + kesim45Maliyet;
    const maliyet = malzeme + iscilik;
    const satis   = maliyet * (1 + n(form.karYuzdesi) / 100);
    const kar     = satis - maliyet;
    return { toplamMtul, toplamDakika, plakaSayisi, malzeme, iscilik, maliyet, satis, kar,
      tezgahMaliyet, tezgahArasiMaliyet, adaMaliyet, stresAlmaMaliyet, fasonMaliyet,
      kesim45Maliyet, pahlamaMaliyet: 0, yapistirmaMaliyet: 0 };
  }, [form, makineler]);

  function fiyatAnaliziSatirlari() {
    const satis   = hesap.satis || 0;
    const tezgah  = n(form.metrajMtul);
    const arasi   = n(form.tezgahArasiMtul);
    const ada     = n(form.adaTezgahMtul);
    const weighted= tezgah * 1 + arasi * 0.75 + ada * 1.5;
    const baz     = weighted > 0 ? satis / weighted : 0;
    return [
      tezgah > 0 ? { ad:"Tezgah",       mtul:tezgah, katsayi:1,    birim:baz,      toplam:tezgah*baz     } : null,
      arasi  > 0 ? { ad:"Tezgah Arası", mtul:arasi,  katsayi:0.75, birim:baz*0.75, toplam:arasi*baz*0.75 } : null,
      ada    > 0 ? { ad:"Ada Tezgah",   mtul:ada,    katsayi:1.5,  birim:baz*1.5,  toplam:ada*baz*1.5    } : null,
    ].filter(Boolean) as any[];
  }
  function fiyatKarari() {
    const kar = n(form.karYuzdesi);
    if (kar >= 60) return { baslik:"Premium fiyat",  metin:"Kâr güçlü. Değer anlatımı ile savunulmalı.",           renk:"text-emerald-300" };
    if (kar >= 35) return { baslik:"Sağlıklı fiyat", metin:"Fiyat dengeli. Pazarlık payı kontrollü bırakılabilir.", renk:"text-blue-300"    };
    if (kar >= 20) return { baslik:"Dikkatli fiyat", metin:"Marj daralıyor. Ek işçilik ve fire riski korunmalı.",   renk:"text-amber-300"   };
    return           { baslik:"Riskli fiyat",         metin:"Bu fiyat hata affetmez. Mümkünse yukarı çek.",         renk:"text-red-300"     };
  }
  function fiyatPanelToplam() {
    return fiyatAnaliziSatirlari().reduce((acc, r) => acc + Number(fiyatOverride[r.ad] ?? r.birim) * r.mtul, 0);
  }
  function fiyatPanelKar()      { return fiyatPanelToplam() - (hesap.maliyet || 0); }
  function fiyatPanelKarYuzde() { return hesap.maliyet > 0 ? (fiyatPanelKar() / hesap.maliyet) * 100 : 0; }

  async function manuelFiyatlariKaydet() {
    if (!sonKayitIsId) { alert("Önce teklif kaydedilmeli."); return; }
    const s = fiyatAnaliziSatirlari();
    const payload = {
      tezgahBirimFiyatOverride:      Number(fiyatOverride["Tezgah"]       ?? s.find((x)=>x.ad==="Tezgah")?.birim       ?? 0),
      tezgahArasiBirimFiyatOverride: Number(fiyatOverride["Tezgah Arası"] ?? s.find((x)=>x.ad==="Tezgah Arası")?.birim ?? 0),
      adaBirimFiyatOverride:         Number(fiyatOverride["Ada Tezgah"]   ?? s.find((x)=>x.ad==="Ada Tezgah")?.birim   ?? 0),
    };
    const res = await fetch(`/api/isler/${sonKayitIsId}/fiyat`, { method:"PUT", headers:{"Content-Type":"application/json"}, body:JSON.stringify(payload) });
    const raw = await res.text();
    let veri: any = {}; try { veri = raw ? JSON.parse(raw) : {}; } catch { veri = { hata: raw }; }
    if (!res.ok) { alert(veri?.hata || "Fiyat kaydedilemedi."); return; }
    alert("Manuel fiyatlar kaydedildi.");
  }

  function onlineTeklifLinki() { return sonKayitTeklifNo ? `${window.location.origin}/teklif/${sonKayitTeklifNo}` : ""; }
  function whatsappTeklifGonder() {
    const link = onlineTeklifLinki();
    if (!link) { alert("Kaydetme tamamlandıktan sonra tekrar dene."); return; }
    window.open(`https://wa.me/?text=${encodeURIComponent(`Merhaba, teklifinizi aşağıdaki linkten inceleyip onaylayabilirsiniz:\n\n${link}`)}`, "_blank");
  }
  async function teklifLinkiKopyala() {
    const link = onlineTeklifLinki(); if (!link) return;
    await navigator.clipboard.writeText(link); alert("Teklif linki kopyalandı.");
  }
  function pdfTeklifAc() {
    if (!sonKayitIsId) { alert("PDF için kayıt henüz oluşmadı."); return; }
    window.open(`/api/isler/${sonKayitIsId}/pdf`, "_blank");
  }

  async function kaydet() {
    if (!form.musteriAdi.trim()) return alert("Müşteri adı gerekli.");
    if (!form.urunAdi.trim())    return alert("Ürün / taş adı gerekli.");
    const operasyonlar = [
      { tip:"tezgah",             mtul:n(form.metrajMtul),      dakika:n(form.birMtulDakika),      makineId:form.tezgahMakineId        },
      { tip:"tezgah_arasi",       mtul:n(form.tezgahArasiMtul), dakika:n(form.tezgahArasiDakika),  makineId:form.tezgahArasiMakineId   },
      { tip:"ada",                mtul:n(form.adaTezgahMtul),   dakika:n(form.adaTezgahDakika),    makineId:form.adaMakineId           },
      { tip:"stres_alma",         mtul:n(form.ozelIscilik1Mtul),dakika:n(form.ozelIscilik1Dakika), makineId:form.stresAlmaMakineId     },
      { tip:"fason_ebatlama",     mtul:n(form.ozelIscilik2Mtul),dakika:n(form.ozelIscilik2Dakika), makineId:form.fasonEbatlamaMakineId },
      { tip:"45_kesim",           mtul:n(form.kesim45Mtul),     dakika:n(form.kesim45Dakika),      makineId:form.kesim45MakineId       },
      { tip:"pahlama",            mtul:n(form.pahlamaMtul),     dakika:n(form.pahlamaDakika),      makineId:form.pahlamaMakineId       },
